enum AdjustmentTargetType {
  PAYROLL_RUN
  DISBURSEMENT_BATCH
  DISBURSEMENT_ITEM
  PAYROLL_LINE_ITEM
}

enum AdjustmentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
