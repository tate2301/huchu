  DISBURSEMENT_BATCH
  ADJUSTMENT_ENTRY
  COMPENSATION_PROFILE
  COMPENSATION_RULE
  GOLD_SHIFT_ALLOCATION
}

enum ApprovalActionType {
  CREATE
