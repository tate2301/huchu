// Huchu Enterprises - Mine Operations Digitalization System
// Prisma Schema for 5 small-scale gold mines in Zimbabwe

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// CORE ENTITIES - Company, Sites, Users
// ============================================

model Company {
  id                   String             @id @default(uuid())
  name                 String
  slug                 String             @unique
  tenantStatus         TenantStatus       @default(PROVISIONING)
  isProvisioned        Boolean            @default(false)
  suspendedAt          DateTime?
  disabledAt           DateTime?
  payrollCycle         PayrollCycle       @default(MONTHLY)
  goldPayoutCycle      PayrollCycle       @default(FORTNIGHTLY)
  goldSettlementMode   GoldSettlementMode @default(CURRENT_PERIOD)
  cashDisbursementOnly Boolean            @default(true)
  autoGeneratePayrollPeriods  Boolean     @default(true)
  autoGenerateGoldPayoutPeriods Boolean   @default(true)
  periodGenerationHorizon Int             @default(3)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  sites               Site[]
  users               User[]
  employees           Employee[]
  shiftGroups         ShiftGroup[]
  shiftGroupSchedules ShiftGroupSchedule[]
  departments         Department[]
  jobGrades           JobGrade[]
  compensationRules   CompensationRule[]
  compensationTemplates CompensationTemplate[]
  payrollPeriods      PayrollPeriod[]
  payrollRuns         PayrollRun[]
  disbursementBatches DisbursementBatch[]
  approvalActions     ApprovalAction[]
  adjustmentEntries   AdjustmentEntry[]
  notifications       Notification[]
  hrIncidents         HrIncident[]
  disciplinaryActions DisciplinaryAction[]
  subscriptions       CompanySubscription[]
  featureFlags        CompanyFeatureFlag[]
  provisioningEvents  ProvisioningEvent[]
  subdomainReservations SubdomainReservation[]
  branding            CompanyBranding?
  domains             CompanyDomain[]
  supportAccessRequests SupportAccessRequest[]
  supportSessions       SupportSession[]
  runbookDefinitions    RunbookDefinition[]
  runbookExecutions     RunbookExecution[]
  sloMetricSnapshots    TenantSloMetricSnapshot[]
  healthIncidents       HealthIncident[]
  contractEnforcementEvents ContractEnforcementEvent[]
  auditLedgerEvents     PlatformAuditEvent[]
  subscriptionAddons    CompanySubscriptionAddon[]
  accountingSettings   AccountingSettings?
  chartOfAccounts      ChartOfAccount[]
  accountingPeriods    AccountingPeriod[]
  journalEntries       JournalEntry[]
  postingRules         PostingRule[]
  taxCodes             TaxCode[]
  customers            Customer[]
  vendors              Vendor[]
  salesInvoices        SalesInvoice[]
  salesReceipts        SalesReceipt[]
  creditNotes          CreditNote[]
  salesWriteOffs       SalesWriteOff[]
  purchaseBills        PurchaseBill[]
  purchasePayments     PurchasePayment[]
  debitNotes           DebitNote[]
  purchaseWriteOffs    PurchaseWriteOff[]
  bankAccounts         BankAccount[]
  bankTransactions     BankTransaction[]
  bankReconciliations  BankReconciliation[]
  vatReturnSummaries   VatReturnSummary[]
  fixedAssets          FixedAsset[]
  budgets              Budget[]
  budgetLines          BudgetLine[]
  costCenters          CostCenter[]
  currencyRates        CurrencyRate[]
  fiscalProviderConfigs FiscalisationProviderConfig[]
  fiscalReceipts       FiscalReceipt[]
  accountingIntegrationEvents AccountingIntegrationEvent[]
  idSequences          IdSequence[]
  goldPurchases        GoldPurchase[]
  goldPrices          GoldPrice[]

  @@index([tenantStatus])
  @@index([isProvisioned])
}

model IdSequence {
  id        String   @id @default(uuid())
  companyId String
  entityKey String
  scopeKey  String   @default("GLOBAL")
  lastNumber Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, entityKey, scopeKey])
  @@index([companyId])
}

enum TenantStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  DISABLED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  description  String?
  monthlyPrice Float
  annualPrice  Float?
  currency     String   @default("USD")
  maxSites     Int?
  maxUsers     Int?
  warningDays  Int      @default(14)
  graceDays    Int      @default(7)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions CompanySubscription[]

  @@index([isActive])
}

model CompanySubscription {
  id                     String             @id @default(uuid())
  companyId              String
  planId                 String
  status                 SubscriptionStatus @default(TRIALING)
  externalSubscriptionId String?            @unique
  startedAt              DateTime           @default(now())
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  endedAt                DateTime?
  effectiveMonthlyAmount Float?
  priceSnapshotJson      String?
  lastPriceComputedAt    DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan    SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([companyId, status])
  @@index([planId])
  @@index([currentPeriodEnd])
}

model PlatformFeature {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  domain      String?
  defaultEnabled Boolean @default(false)
  isBillable  Boolean  @default(false)
  monthlyPrice Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyFlags CompanyFeatureFlag[]
  bundleItems  FeatureBundleItem[]
  userFlags    UserFeatureFlag[]

  @@index([isActive])
}

model CompanyFeatureFlag {
  id        String   @id @default(uuid())
  companyId String
  featureId String
  isEnabled Boolean  @default(true)
  reason    String?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  feature PlatformFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([companyId, featureId])
  @@index([featureId])
  @@index([companyId, isEnabled])
}

model UserFeatureFlag {
  id        String   @id @default(uuid())
  userId    String
  featureId String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature PlatformFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([userId, featureId])
  @@index([featureId])
  @@index([userId, isEnabled])
}

model FeatureBundle {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  monthlyPrice Float   @default(0)
  additionalSiteMonthlyPrice Float @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items            FeatureBundleItem[]
  companyAddons    CompanySubscriptionAddon[]

  @@index([isActive])
}

model FeatureBundleItem {
  id        String   @id @default(uuid())
  bundleId  String
  featureId String
  createdAt DateTime @default(now())

  bundle  FeatureBundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  feature PlatformFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([bundleId, featureId])
  @@index([featureId])
}

model CompanySubscriptionAddon {
  id        String   @id @default(uuid())
  companyId String
  bundleId  String
  isEnabled Boolean  @default(true)
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bundle  FeatureBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([companyId, bundleId])
  @@index([bundleId, isEnabled])
}

model ProvisioningEvent {
  id          String   @id @default(uuid())
  companyId   String
  eventType   String
  status      String   @default("PENDING")
  message     String?
  payloadJson String?
  errorJson   String?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([status])
}

enum SubdomainReservationStatus {
  RESERVED
  ACTIVE
  RELEASED
}

enum CompanyDomainStatus {
  PENDING_VERIFICATION
  VERIFIED
  ACTIVE
  FAILED
  DISABLED
}

enum CompanyDomainVerificationType {
  TXT
}

model SubdomainReservation {
  id            String                     @id @default(uuid())
  companyId     String
  subdomain     String                     @unique
  status        SubdomainReservationStatus @default(RESERVED)
  provider      String                     @default("registry-stub")
  providerRef   String?
  lastCheckedAt DateTime?
  reservedAt    DateTime                   @default(now())
  activatedAt   DateTime?
  releasedAt    DateTime?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
}

model CompanyBranding {
  companyId     String   @id
  displayName   String?
  primaryColor  String?
  secondaryColor String?
  accentColor   String?
  fontFamilyKey String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CompanyDomain {
  id               String                        @id @default(uuid())
  companyId        String
  hostname         String                        @unique
  status           CompanyDomainStatus           @default(PENDING_VERIFICATION)
  verificationType CompanyDomainVerificationType @default(TXT)
  verificationHost String
  verificationValue String
  lastCheckedAt    DateTime?
  verifiedAt       DateTime?
  activatedAt      DateTime?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([status])
}

enum SupportAccessStatus {
  REQUESTED
  APPROVED
  ACTIVE
  EXPIRED
  REVOKED
  DENIED
}

enum SupportAccessScope {
  READ_ONLY
  READ_WRITE
}

enum SupportSessionMode {
  IMPERSONATE
  SHADOW
}

model SupportAccessRequest {
  id          String              @id @default(uuid())
  companyId   String
  requestedBy String
  approvedBy  String?
  reason      String
  scope       SupportAccessScope  @default(READ_ONLY)
  status      SupportAccessStatus @default(REQUESTED)
  requestedAt DateTime            @default(now())
  approvedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([requestedBy])
}

model SupportSession {
  id         String              @id @default(uuid())
  requestId  String?
  companyId  String
  actor      String
  mode       SupportSessionMode  @default(IMPERSONATE)
  scope      SupportAccessScope  @default(READ_ONLY)
  status     SupportAccessStatus @default(ACTIVE)
  reason     String
  startedAt  DateTime            @default(now())
  endedAt    DateTime?
  expiresAt  DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([requestId])
  @@index([actor])
}

enum RunbookRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum RunbookExecutionStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  CANCELED
}

model RunbookDefinition {
  id         String           @id @default(uuid())
  companyId  String?
  name       String
  actionType String
  schedule   String?
  enabled    Boolean          @default(true)
  riskLevel  RunbookRiskLevel @default(LOW)
  inputJson  String?
  createdBy  String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  company    Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  executions RunbookExecution[]

  @@index([companyId, enabled])
  @@index([actionType])
}

model RunbookExecution {
  id         String                 @id @default(uuid())
  runbookId  String
  companyId  String?
  status     RunbookExecutionStatus @default(QUEUED)
  dryRun     Boolean                @default(false)
  startedAt  DateTime               @default(now())
  finishedAt DateTime?
  resultJson String?
  errorJson  String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  runbook RunbookDefinition @relation(fields: [runbookId], references: [id], onDelete: Cascade)
  company Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([runbookId, createdAt])
  @@index([companyId, createdAt])
  @@index([status])
}

model TenantSloMetricSnapshot {
  id          String   @id @default(uuid())
  companyId   String
  metricKey   String
  value       Float
  status      String   @default("OK")
  windowStart DateTime?
  windowEnd   DateTime?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, metricKey, createdAt])
}

enum HealthIncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model HealthIncident {
  id             String               @id @default(uuid())
  companyId      String
  metricKey      String
  riskLevel      RunbookRiskLevel     @default(LOW)
  actionType     String
  status         HealthIncidentStatus @default(OPEN)
  message        String
  actualValue    Float?
  thresholdValue Float?
  createdAt      DateTime             @default(now())
  resolvedAt     DateTime?
  updatedAt      DateTime             @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status, createdAt])
  @@index([riskLevel, status])
}

enum ContractAccessState {
  ACTIVE
  WARNING
  SUSPENDED
  OVERRIDE
}

model ContractEnforcementEvent {
  id          String              @id @default(uuid())
  companyId   String
  fromState   ContractAccessState
  toState     ContractAccessState
  reason      String
  overrideBy  String?
  expiresAt   DateTime?
  effectiveAt DateTime            @default(now())
  createdAt   DateTime            @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model PlatformAuditEvent {
  id           String   @id @default(uuid())
  companyId    String?
  actor        String?
  eventType    String
  entityType   String?
  entityId     String?
  reason       String?
  payloadJson  String?
  eventHash    String   @unique
  prevEventHash String?
  createdAt    DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([eventType, createdAt])
}

model Site {
  id        String  @id @default(uuid())
  name      String
  code      String
  location  String?
  companyId String
  isActive  Boolean @default(true)

  // Configurable per site
  measurementUnit String @default("tonnes") // tonnes, trips, wheelbarrows

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company              Company               @relation(fields: [companyId], references: [id])
  sections             Section[]
  shiftGroups          ShiftGroup[]
  shiftGroupSchedules  ShiftGroupSchedule[]
  shiftReports         ShiftReport[]
  plantReports         PlantReport[]
  goldPours            GoldPour[]
  goldPurchases        GoldPurchase[]
  goldShiftAllocations GoldShiftAllocation[]
  attendance           Attendance[]
  equipment            Equipment[]
  inventory            InventoryItem[]
  permits              Permit[]
  incidents            Incident[]
  hrIncidents          HrIncident[]
  inspections          Inspection[]
  stockLocations       StockLocation[]
  downtimeCodes        DowntimeCode[]
  nvrs                 NVR[]
  cameras              Camera[]
  streamSessions       StreamSession[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Section {
  id        String   @id @default(uuid())
  name      String // shaft, level, pit name
  siteId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site         Site          @relation(fields: [siteId], references: [id])
  shiftReports ShiftReport[]

  @@index([siteId])
}

enum UserRole {
  SUPERADMIN
  MANAGER
  CLERK
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  password      String? // Optional for OAuth users
  role          UserRole
  companyId     String
  phone         String?
  isActive      Boolean   @default(true)
  emailVerified DateTime? // For NextAuth
  image         String? // For NextAuth
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company                       Company                     @relation(fields: [companyId], references: [id])
  createdShiftReports           ShiftReport[]               @relation("CreatedBy")
  createdShiftGroupSchedules    ShiftGroupSchedule[]        @relation("ShiftGroupScheduleCreatedBy")
  verifiedShiftReports          ShiftReport[]               @relation("VerifiedBy")
  approvedShiftReports          ShiftReport[]               @relation("ApprovedBy")
  plantReports                  PlantReport[]
  createdGoldShiftAllocations   GoldShiftAllocation[]       @relation("GoldShiftAllocationCreatedBy")
  submittedGoldShiftAllocations GoldShiftAllocation[]       @relation("GoldShiftAllocationSubmittedBy")
  approvedGoldShiftAllocations  GoldShiftAllocation[]       @relation("GoldShiftAllocationApprovedBy")
  createdGoldPurchases          GoldPurchase[]              @relation("GoldPurchaseCreatedBy")
  stockMovements                StockMovement[]
  inspections                   Inspection[]
  trainingRecords               TrainingRecord[]
  reportedHrIncidents           HrIncident[]               @relation("HrIncidentReportedBy")
  resolvedHrIncidents           HrIncident[]               @relation("HrIncidentResolvedBy")
  createdDisciplinaryActions    DisciplinaryAction[]       @relation("DisciplinaryActionCreatedBy")
  submittedDisciplinaryActions  DisciplinaryAction[]       @relation("DisciplinaryActionSubmittedBy")
  approvedDisciplinaryActions   DisciplinaryAction[]       @relation("DisciplinaryActionApprovedBy")
  appliedDisciplinaryActions    DisciplinaryAction[]       @relation("DisciplinaryActionAppliedBy")
  employeePayments              EmployeePayment[]
  streamSessions                StreamSession[]
  createdCompensationProfiles   CompensationProfile[]       @relation("CompProfileCreatedBy")
  submittedCompensationProfiles CompensationProfile[]       @relation("CompProfileSubmittedBy")
  approvedCompensationProfiles  CompensationProfile[]       @relation("CompProfileApprovedBy")
  createdCompensationRules      CompensationRule[]          @relation("CompRuleCreatedBy")
  submittedCompensationRules    CompensationRule[]          @relation("CompRuleSubmittedBy")
  approvedCompensationRules     CompensationRule[]          @relation("CompRuleApprovedBy")
  createdCompensationTemplates  CompensationTemplate[]       @relation("CompTemplateCreatedBy")
  createdPayrollPeriods         PayrollPeriod[]             @relation("PayrollPeriodCreatedBy")
  submittedPayrollPeriods       PayrollPeriod[]             @relation("PayrollPeriodSubmittedBy")
  approvedPayrollPeriods        PayrollPeriod[]             @relation("PayrollPeriodApprovedBy")
  createdPayrollRuns            PayrollRun[]                @relation("PayrollRunCreatedBy")
  submittedPayrollRuns          PayrollRun[]                @relation("PayrollRunSubmittedBy")
  approvedPayrollRuns           PayrollRun[]                @relation("PayrollRunApprovedBy")
  createdDisbursementBatches    DisbursementBatch[]         @relation("DisbursementBatchCreatedBy")
  submittedDisbursementBatches  DisbursementBatch[]         @relation("DisbursementBatchSubmittedBy")
  approvedDisbursementBatches   DisbursementBatch[]         @relation("DisbursementBatchApprovedBy")
  approvalActions               ApprovalAction[]            @relation("ApprovalActionActor")
  createdAdjustmentEntries      AdjustmentEntry[]           @relation("AdjustmentCreatedBy")
  submittedAdjustmentEntries    AdjustmentEntry[]           @relation("AdjustmentSubmittedBy")
  approvedAdjustmentEntries     AdjustmentEntry[]           @relation("AdjustmentApprovedBy")
  createdJournalEntries         JournalEntry[]              @relation("JournalEntryCreatedBy")
  postedJournalEntries          JournalEntry[]              @relation("JournalEntryPostedBy")
  reversedJournalEntries        JournalEntry[]              @relation("JournalEntryReversedBy")
  voidedJournalEntries          JournalEntry[]              @relation("JournalEntryVoidedBy")
  periodOverrideJournalEntries  JournalEntry[]              @relation("JournalEntryPeriodOverrideBy")
  closedAccountingPeriods       AccountingPeriod[]          @relation("AccountingPeriodClosedBy")
  createdSalesInvoices          SalesInvoice[]              @relation("SalesInvoiceCreatedBy")
  issuedSalesInvoices           SalesInvoice[]              @relation("SalesInvoiceIssuedBy")
  createdSalesReceipts          SalesReceipt[]              @relation("SalesReceiptCreatedBy")
  createdCreditNotes            CreditNote[]                @relation("CreditNoteCreatedBy")
  issuedCreditNotes             CreditNote[]                @relation("CreditNoteIssuedBy")
  createdSalesWriteOffs         SalesWriteOff[]             @relation("SalesWriteOffCreatedBy")
  createdPurchaseBills          PurchaseBill[]              @relation("PurchaseBillCreatedBy")
  issuedPurchaseBills           PurchaseBill[]              @relation("PurchaseBillIssuedBy")
  createdPurchasePayments       PurchasePayment[]           @relation("PurchasePaymentCreatedBy")
  createdDebitNotes             DebitNote[]                 @relation("DebitNoteCreatedBy")
  issuedDebitNotes              DebitNote[]                 @relation("DebitNoteIssuedBy")
  createdPurchaseWriteOffs      PurchaseWriteOff[]          @relation("PurchaseWriteOffCreatedBy")
  createdBankReconciliations    BankReconciliation[]        @relation("BankReconciliationCreatedBy")
  closedBankReconciliations     BankReconciliation[]        @relation("BankReconciliationClosedBy")
  createdVatReturns             VatReturnSummary[]          @relation("VatReturnCreatedBy")
  notificationRecipients        NotificationRecipient[]
  notificationPreference        UserNotificationPreference?
  webPushSubscriptions          WebPushSubscription[]
  featureFlags                  UserFeatureFlag[]
  accounts                      Account[] // For NextAuth
  sessions                      Session[] // For NextAuth

  @@index([companyId])
  @@index([email])
}

model Employee {
  id               String           @id @default(uuid())
  employeeId       String
  name             String
  phone            String
  nextOfKinName    String
  nextOfKinPhone   String
  passportPhotoUrl String
  nationalIdNumber String?
  nationalIdDocumentUrl String?
  villageOfOrigin  String
  position         EmployeePosition @default(MINERS)
  departmentId     String?
  gradeId          String?
  supervisorId     String?
  employmentType   EmploymentType   @default(FULL_TIME)
  hireDate         DateTime?
  terminationDate  DateTime?
  defaultCurrency  String           @default("USD")
  companyId        String
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  company                   Company                @relation(fields: [companyId], references: [id])
  department                Department?            @relation(fields: [departmentId], references: [id])
  grade                     JobGrade?              @relation(fields: [gradeId], references: [id])
  supervisor                Employee?              @relation("EmployeeSupervisor", fields: [supervisorId], references: [id])
  supervisees               Employee[]             @relation("EmployeeSupervisor")
  attendance                Attendance[]
  ledShiftGroups            ShiftGroup[]            @relation("ShiftGroupLeader")
  shiftGroupMemberships     ShiftGroupMember[]
  groupLeaderReports        ShiftReport[]          @relation("GroupLeaderReports")
  workOrders                WorkOrder[]            @relation("WorkOrderTechnicians")
  goldPoursWitness1         GoldPour[]             @relation("Witness1")
  goldPoursWitness2         GoldPour[]             @relation("Witness2")
  goldDispatches            GoldDispatch[]         @relation("GoldDispatchHandovers")
  soldGoldPurchases         GoldPurchase[]         @relation("GoldPurchaseSeller")
  receivedGoldPurchases1    GoldPurchase[]         @relation("GoldPurchaseReceiver1")
  receivedGoldPurchases2    GoldPurchase[]         @relation("GoldPurchaseReceiver2")
  goldShiftWorkerShares     GoldShiftWorkerShare[]
  fixedSalary               FixedSalary?
  payments                  EmployeePayment[]
  compensationProfiles      CompensationProfile[]
  targetedCompensationRules CompensationRule[]     @relation("CompRuleEmployeeTarget")
  payrollLineItems          PayrollLineItem[]
  disbursementItems         DisbursementItem[]
  adjustmentEntries         AdjustmentEntry[]
  hrIncidents               HrIncident[]
  disciplinaryActions       DisciplinaryAction[]

  @@unique([companyId, employeeId])
  @@unique([companyId, nationalIdNumber])
  @@index([companyId])
  @@index([departmentId])
  @@index([gradeId])
  @@index([supervisorId])
}

model FixedSalary {
  id            String   @id @default(uuid())
  employeeId    String   @unique
  monthlyAmount Float
  currency      String   @default("USD")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model EmployeePayment {
  id                  String        @id @default(uuid())
  employeeId          String
  type                PaymentType
  periodStart         DateTime
  periodEnd           DateTime
  dueDate             DateTime
  amount              Float
  unit                String
  paidAmount          Float?
  paidAt              DateTime?
  status              PaymentStatus @default(DUE)
  notes               String?
  goldWeightGrams     Float?
  goldPriceUsdPerGram Float?
  valuationDate       DateTime?
  amountUsd           Float?
  paidAmountUsd       Float?
  payrollRunId        String?
  payrollLineItemId   String?
  disbursementBatchId String?
  disbursementItemId  String?
  createdById         String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  employee          Employee           @relation(fields: [employeeId], references: [id])
  createdBy         User               @relation(fields: [createdById], references: [id])
  payrollRun        PayrollRun?        @relation(fields: [payrollRunId], references: [id])
  payrollLineItem   PayrollLineItem?   @relation(fields: [payrollLineItemId], references: [id])
  disbursementBatch DisbursementBatch? @relation(fields: [disbursementBatchId], references: [id])
  disbursementItem  DisbursementItem?  @relation(fields: [disbursementItemId], references: [id])

  @@index([employeeId, type])
  @@index([payrollRunId])
  @@index([payrollLineItemId])
  @@index([disbursementBatchId])
  @@index([disbursementItemId])
}

model Department {
  id        String   @id @default(uuid())
  companyId String
  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company           Company            @relation(fields: [companyId], references: [id])
  employees         Employee[]
  compensationRules CompensationRule[]

  @@unique([companyId, code])
  @@index([companyId])
}

model JobGrade {
  id        String   @id @default(uuid())
  companyId String
  code      String
  name      String
  rank      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company           Company            @relation(fields: [companyId], references: [id])
  employees         Employee[]
  compensationRules CompensationRule[]

  @@unique([companyId, code])
  @@index([companyId])
}

model CompensationProfile {
  id             String                    @id @default(uuid())
  employeeId     String
  baseAmount     Float
  currency       String                    @default("USD")
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  status         CompensationProfileStatus @default(ACTIVE)
  workflowStatus WorkflowStatus            @default(DRAFT)
  notes          String?
  createdById    String
  submittedById  String?
  approvedById   String?
  submittedAt    DateTime?
  approvedAt     DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  employee    Employee          @relation(fields: [employeeId], references: [id])
  createdBy   User              @relation("CompProfileCreatedBy", fields: [createdById], references: [id])
  submittedBy User?             @relation("CompProfileSubmittedBy", fields: [submittedById], references: [id])
  approvedBy  User?             @relation("CompProfileApprovedBy", fields: [approvedById], references: [id])
  lineItems   PayrollLineItem[]

  @@index([employeeId, status])
  @@index([workflowStatus])
  @@index([effectiveFrom])
}

model CompensationRule {
  id             String                 @id @default(uuid())
  companyId      String
  name           String
  type           CompensationRuleType
  calcMethod     CompensationCalcMethod
  value          Float
  cap            Float?
  taxable        Boolean                @default(false)
  currency       String                 @default("USD")
  isActive       Boolean                @default(true)
  workflowStatus WorkflowStatus         @default(DRAFT)
  employeeId     String?
  departmentId   String?
  gradeId        String?
  createdById    String
  submittedById  String?
  approvedById   String?
  submittedAt    DateTime?
  approvedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  company     Company                @relation(fields: [companyId], references: [id])
  employee    Employee?              @relation("CompRuleEmployeeTarget", fields: [employeeId], references: [id])
  department  Department?            @relation(fields: [departmentId], references: [id])
  grade       JobGrade?              @relation(fields: [gradeId], references: [id])
  createdBy   User                   @relation("CompRuleCreatedBy", fields: [createdById], references: [id])
  submittedBy User?                  @relation("CompRuleSubmittedBy", fields: [submittedById], references: [id])
  approvedBy  User?                  @relation("CompRuleApprovedBy", fields: [approvedById], references: [id])
  components  PayrollLineComponent[]
  templateLinks CompensationTemplateRule[]

  @@index([companyId, isActive])
  @@index([workflowStatus])
  @@index([employeeId])
  @@index([departmentId])
  @@index([gradeId])
}

model CompensationTemplate {
  id             String          @id @default(uuid())
  companyId      String
  name           String
  description    String?
  employmentType EmploymentType?
  position       EmployeePosition?
  baseAmount     Float
  currency       String          @default("USD")
  isActive       Boolean         @default(true)
  createdById    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  company   Company                   @relation(fields: [companyId], references: [id])
  createdBy User                      @relation("CompTemplateCreatedBy", fields: [createdById], references: [id])
  rules     CompensationTemplateRule[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
  @@index([employmentType, position])
}

model CompensationTemplateRule {
  id                 String @id @default(uuid())
  templateId         String
  compensationRuleId String
  sortOrder          Int    @default(0)

  template         CompensationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  compensationRule CompensationRule     @relation(fields: [compensationRuleId], references: [id])

  @@unique([templateId, compensationRuleId])
  @@index([compensationRuleId])
}

model PayrollPeriod {
  id            String              @id @default(uuid())
  companyId     String
  domain        RunDomain           @default(PAYROLL)
  periodKey     String
  startDate     DateTime
  endDate       DateTime
  dueDate       DateTime
  cycle         PayrollCycle        @default(MONTHLY)
  status        PayrollPeriodStatus @default(DRAFT)
  isAutoGenerated Boolean           @default(false)
  periodPurpose PeriodPurpose       @default(STANDARD)
  appliesToContractorsOnly Boolean  @default(false)
  employeeScopeJson String?
  notes         String?
  createdById   String
  submittedById String?
  approvedById  String?
  submittedAt   DateTime?
  approvedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  company     Company      @relation(fields: [companyId], references: [id])
  createdBy   User         @relation("PayrollPeriodCreatedBy", fields: [createdById], references: [id])
  submittedBy User?        @relation("PayrollPeriodSubmittedBy", fields: [submittedById], references: [id])
  approvedBy  User?        @relation("PayrollPeriodApprovedBy", fields: [approvedById], references: [id])
  runs        PayrollRun[]

  @@unique([companyId, domain, periodKey])
  @@index([companyId, domain, startDate])
  @@index([status])
}

model PayrollRun {
  id                 String             @id @default(uuid())
  companyId          String
  periodId           String
  domain             RunDomain          @default(PAYROLL)
  runNumber          Int                @default(1)
  status             PayrollRunStatus   @default(DRAFT)
  notes              String?
  grossTotal         Float              @default(0)
  allowancesTotal    Float              @default(0)
  deductionsTotal    Float              @default(0)
  netTotal           Float              @default(0)
  goldRatePerUnit    Float?
  goldRateUnit       String             @default("g")
  goldSettlementMode GoldSettlementMode @default(CURRENT_PERIOD)
  createdById        String
  submittedById      String?
  approvedById       String?
  submittedAt        DateTime?
  approvedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  company             Company             @relation(fields: [companyId], references: [id])
  period              PayrollPeriod       @relation(fields: [periodId], references: [id])
  createdBy           User                @relation("PayrollRunCreatedBy", fields: [createdById], references: [id])
  submittedBy         User?               @relation("PayrollRunSubmittedBy", fields: [submittedById], references: [id])
  approvedBy          User?               @relation("PayrollRunApprovedBy", fields: [approvedById], references: [id])
  lineItems           PayrollLineItem[]
  disbursementBatches DisbursementBatch[]
  adjustments         AdjustmentEntry[]
  legacyPayments      EmployeePayment[]

  @@unique([periodId, runNumber])
  @@index([companyId, status, domain])
}

model PayrollLineItem {
  id                    String   @id @default(uuid())
  runId                 String
  employeeId            String
  compensationProfileId String?
  baseAmount            Float    @default(0)
  variableAmount        Float    @default(0)
  allowancesTotal       Float    @default(0)
  deductionsTotal       Float    @default(0)
  grossAmount           Float    @default(0)
  netAmount             Float    @default(0)
  currency              String   @default("USD")
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  run                 PayrollRun             @relation(fields: [runId], references: [id], onDelete: Cascade)
  employee            Employee               @relation(fields: [employeeId], references: [id])
  compensationProfile CompensationProfile?   @relation(fields: [compensationProfileId], references: [id])
  components          PayrollLineComponent[]
  disbursementItems   DisbursementItem[]
  adjustments         AdjustmentEntry[]
  legacyPayments      EmployeePayment[]

  @@unique([runId, employeeId])
  @@index([employeeId])
  @@index([compensationProfileId])
}

model PayrollLineComponent {
  id           String                 @id @default(uuid())
  lineItemId   String
  ruleId       String?
  name         String
  type         CompensationRuleType
  calcMethod   CompensationCalcMethod
  rateOrAmount Float
  amount       Float
  isTaxable    Boolean                @default(false)
  createdAt    DateTime               @default(now())

  lineItem PayrollLineItem   @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  rule     CompensationRule? @relation(fields: [ruleId], references: [id])

  @@index([lineItemId])
  @@index([ruleId])
}

model DisbursementBatch {
  id            String                  @id @default(uuid())
  companyId     String
  payrollRunId  String
  code          String
  status        DisbursementBatchStatus @default(DRAFT)
  method        PayoutMethod            @default(CASH)
  notes         String?
  cashCustodian String?
  cashIssuedAt  DateTime?
  totalAmount   Float                   @default(0)
  itemCount     Int                     @default(0)
  createdById   String
  submittedById String?
  approvedById  String?
  submittedAt   DateTime?
  approvedAt    DateTime?
  paidAt        DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  company        Company            @relation(fields: [companyId], references: [id])
  payrollRun     PayrollRun         @relation(fields: [payrollRunId], references: [id])
  createdBy      User               @relation("DisbursementBatchCreatedBy", fields: [createdById], references: [id])
  submittedBy    User?              @relation("DisbursementBatchSubmittedBy", fields: [submittedById], references: [id])
  approvedBy     User?              @relation("DisbursementBatchApprovedBy", fields: [approvedById], references: [id])
  items          DisbursementItem[]
  adjustments    AdjustmentEntry[]
  legacyPayments EmployeePayment[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([payrollRunId])
}

model DisbursementItem {
  id               String        @id @default(uuid())
  batchId          String
  lineItemId       String
  employeeId       String
  amount           Float
  paidAmount       Float?
  status           PaymentStatus @default(DUE)
  paidAt           DateTime?
  receiptReference String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  batch          DisbursementBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  lineItem       PayrollLineItem   @relation(fields: [lineItemId], references: [id])
  employee       Employee          @relation(fields: [employeeId], references: [id])
  adjustments    AdjustmentEntry[]
  legacyPayments EmployeePayment[]

  @@unique([batchId, employeeId])
  @@index([lineItemId])
  @@index([employeeId])
}

model ApprovalAction {
  id         String             @id @default(uuid())
  companyId  String
  entityType ApprovalTargetType
  entityId   String
  action     ApprovalActionType
  fromStatus String?
  toStatus   String?
  note       String?
  actedById  String
  actedAt    DateTime           @default(now())
  createdAt  DateTime           @default(now())

  company Company @relation(fields: [companyId], references: [id])
  actedBy User    @relation("ApprovalActionActor", fields: [actedById], references: [id])

  @@index([companyId, entityType, entityId])
  @@index([actedById, actedAt])
}

model Notification {
  id           String                    @id @default(uuid())
  companyId    String
  type         NotificationType
  title        String
  summary      String
  severity     NotificationSeverity      @default(INFO)
  payloadJson  String?
  entityType   NotificationEntityType?
  entityId     String?
  sourceAction NotificationSourceAction?
  expiresAt    DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  company    Company                 @relation(fields: [companyId], references: [id])
  recipients NotificationRecipient[]

  @@index([companyId, createdAt])
  @@index([companyId, type, createdAt])
  @@index([companyId, severity, createdAt])
  @@index([entityType, entityId])
}

model NotificationRecipient {
  id             String    @id @default(uuid())
  notificationId String
  userId         String
  isRead         Boolean   @default(false)
  readAt         DateTime?
  isArchived     Boolean   @default(false)
  archivedAt     DateTime?
  actionTaken    String?
  actedAt        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, createdAt])
  @@index([userId, isRead, isArchived, createdAt])
}

model UserNotificationPreference {
  id             String   @id @default(uuid())
  userId         String   @unique
  inAppEnabled   Boolean  @default(true)
  webPushEnabled Boolean  @default(false)
  hrEnabled      Boolean  @default(true)
  opsEnabled     Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebPushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model AdjustmentEntry {
  id                  String               @id @default(uuid())
  companyId           String
  targetType          AdjustmentTargetType
  payrollRunId        String?
  disbursementBatchId String?
  lineItemId          String?
  disbursementItemId  String?
  employeeId          String?
  amountDelta         Float
  reason              String
  status              AdjustmentStatus     @default(DRAFT)
  createdById         String
  submittedById       String?
  approvedById        String?
  submittedAt         DateTime?
  approvedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  company           Company            @relation(fields: [companyId], references: [id])
  payrollRun        PayrollRun?        @relation(fields: [payrollRunId], references: [id])
  disbursementBatch DisbursementBatch? @relation(fields: [disbursementBatchId], references: [id])
  lineItem          PayrollLineItem?   @relation(fields: [lineItemId], references: [id])
  disbursementItem  DisbursementItem?  @relation(fields: [disbursementItemId], references: [id])
  employee          Employee?          @relation(fields: [employeeId], references: [id])
  createdBy         User               @relation("AdjustmentCreatedBy", fields: [createdById], references: [id])
  submittedBy       User?              @relation("AdjustmentSubmittedBy", fields: [submittedById], references: [id])
  approvedBy        User?              @relation("AdjustmentApprovedBy", fields: [approvedById], references: [id])

  @@index([companyId, targetType, status])
  @@index([employeeId])
}

