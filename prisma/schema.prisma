// Huchu Enterprises - Mine Operations Digitalization System
// Prisma Schema for 5 small-scale gold mines in Zimbabwe

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// CORE ENTITIES - Company, Sites, Users
// ============================================

model Company {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  sites     Site[]
  users     User[]
  employees Employee[]
}

model Site {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  location    String?
  companyId   String
  isActive    Boolean  @default(true)
  
  // Configurable per site
  measurementUnit String @default("tonnes") // tonnes, trips, wheelbarrows
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  company           Company            @relation(fields: [companyId], references: [id])
  sections          Section[]
  shiftReports      ShiftReport[]
  plantReports      PlantReport[]
  goldPours         GoldPour[]
  goldShiftAllocations GoldShiftAllocation[]
  attendance        Attendance[]
  equipment         Equipment[]
  inventory         InventoryItem[]
  permits           Permit[]
  incidents         Incident[]
  inspections       Inspection[]
  stockLocations    StockLocation[]
  downtimeCodes     DowntimeCode[]
  
  @@index([companyId])
}

model Section {
  id        String   @id @default(uuid())
  name      String   // shaft, level, pit name
  siteId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  site          Site           @relation(fields: [siteId], references: [id])
  shiftReports  ShiftReport[]
  
  @@index([siteId])
}

enum UserRole {
  SUPERADMIN
  MANAGER
  CLERK
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  password      String?   // Optional for OAuth users
  role          UserRole
  companyId     String
  phone         String?
  isActive      Boolean   @default(true)
  emailVerified DateTime? // For NextAuth
  image         String?   // For NextAuth
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  company               Company           @relation(fields: [companyId], references: [id])
  createdShiftReports   ShiftReport[]     @relation("CreatedBy")
  verifiedShiftReports  ShiftReport[]     @relation("VerifiedBy")
  approvedShiftReports  ShiftReport[]     @relation("ApprovedBy")
  plantReports          PlantReport[]
  goldShiftAllocations  GoldShiftAllocation[]
  stockMovements        StockMovement[]
  inspections           Inspection[]
  trainingRecords       TrainingRecord[]
  accounts              Account[]         // For NextAuth
  sessions              Session[]         // For NextAuth
  
  @@index([companyId])
  @@index([email])
}

model Employee {
  id                String   @id @default(uuid())
  employeeId        String
  name              String
  phone             String
  nextOfKinName     String
  nextOfKinPhone    String
  passportPhotoUrl  String
  villageOfOrigin   String
  position          EmployeePosition @default(MINERS)
  companyId         String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company           Company    @relation(fields: [companyId], references: [id])
  attendance        Attendance[]
  groupLeaderReports ShiftReport[] @relation("GroupLeaderReports")
  workOrders        WorkOrder[] @relation("WorkOrderTechnicians")
  goldPoursWitness1 GoldPour[]  @relation("Witness1")
  goldPoursWitness2 GoldPour[]  @relation("Witness2")
  goldDispatches    GoldDispatch[] @relation("GoldDispatchHandovers")
  goldShiftWorkerShares GoldShiftWorkerShare[]

  @@unique([companyId, employeeId])
  @@index([companyId])
}

// ============================================
// PHASE 1: DAILY OPERATIONS
// ============================================

enum ShiftType {
  DAY
  NIGHT
}

enum WorkType {
  EXTRACTION
  HAULING
  CRUSHING
  PROCESSING
}

enum EmployeePosition {
  MANAGER
  CLERK
  SUPPORT_STAFF
  ENGINEERS
  CHEMIST
  MINERS
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  VERIFIED
  APPROVED
  REJECTED
}

model ShiftReport {
  id              String       @id @default(uuid())
  date            DateTime
  shift           ShiftType
  siteId          String
  sectionId       String?
  groupLeaderId   String
  crewCount       Int
  workType        WorkType
  
  // Output metrics (flexible per site)
  outputTonnes    Float?
  outputTrips     Int?
  outputWheelbarrows Int?
  metresAdvanced  Float?
  
  // Safety and handover
  hasIncident     Boolean      @default(false)
  incidentNotes   String?
  handoverNotes   String?
  
  // Photos (stored as JSON array of URLs)
  photos          String?      // JSON array
  
  // Workflow
  status          ReportStatus @default(DRAFT)
  createdById     String
  verifiedById    String?
  approvedById    String?
  verifiedAt      DateTime?
  approvedAt      DateTime?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  site            Site         @relation(fields: [siteId], references: [id])
  section         Section?     @relation(fields: [sectionId], references: [id])
  groupLeader     Employee     @relation("GroupLeaderReports", fields: [groupLeaderId], references: [id])
  createdBy       User         @relation("CreatedBy", fields: [createdById], references: [id])
  verifiedBy      User?        @relation("VerifiedBy", fields: [verifiedById], references: [id])
  approvedBy      User?        @relation("ApprovedBy", fields: [approvedById], references: [id])
  downtimeEvents  DowntimeEvent[]
  goldShiftAllocation GoldShiftAllocation?
  
  @@index([siteId, date])
  @@index([date])
}

model DowntimeCode {
  id          String   @id @default(uuid())
  code        String
  description String
  siteId      String?  // null = company-wide defaults
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  
  site        Site?    @relation(fields: [siteId], references: [id])
  events      DowntimeEvent[]
  
  @@index([siteId])
}

model DowntimeEvent {
  id              String      @id @default(uuid())
  shiftReportId   String?
  plantReportId   String?
  downtimeCodeId  String
  durationHours   Float
  notes           String?
  createdAt       DateTime    @default(now())
  
  shiftReport     ShiftReport? @relation(fields: [shiftReportId], references: [id])
  plantReport     PlantReport? @relation(fields: [plantReportId], references: [id])
  downtimeCode    DowntimeCode @relation(fields: [downtimeCodeId], references: [id])
  
  @@index([shiftReportId])
  @@index([plantReportId])
}

model Attendance {
  id          String   @id @default(uuid())
  date        DateTime
  siteId      String
  shift       ShiftType
  employeeId  String
  status      String   // PRESENT, ABSENT, LATE
  overtime    Float?   // hours
  notes       String?
  createdAt   DateTime @default(now())
  
  site        Site     @relation(fields: [siteId], references: [id])
  employee    Employee @relation(fields: [employeeId], references: [id])
  
  @@unique([date, siteId, shift, employeeId])
  @@index([siteId, date])
}

// ============================================
// PHASE 2: PLANT REPORTING
// ============================================

model PlantReport {
  id              String          @id @default(uuid())
  date            DateTime
  siteId          String
  tonnesFed       Float?
  tonnesProcessed Float?
  runHours        Float?
  
  // Consumables
  dieselUsed      Float?
  grindingMedia   Float?
  reagentsUsed    Float?
  waterUsed       Float?
  
  // Gold recovered (if poured)
  goldRecovered   Float?
  
  notes           String?
  reportedById    String
  status          ReportStatus    @default(DRAFT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  site            Site            @relation(fields: [siteId], references: [id])
  reportedBy      User            @relation(fields: [reportedById], references: [id])
  downtimeEvents  DowntimeEvent[]
  
  @@index([siteId, date])
}

// ============================================
// PHASE 3: GOLD CONTROL
// ============================================

model GoldPour {
  id              String       @id @default(uuid())
  pourBarId       String       @unique
  pourDate        DateTime
  siteId          String
  grossWeight     Float
  estimatedPurity Float?
  witness1Id      String
  witness2Id      String
  storageLocation String
  notes           String?
  
  // Audit trail
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  corrections     String?      // JSON log of corrections
  
  site            Site         @relation(fields: [siteId], references: [id])
  witness1        Employee     @relation("Witness1", fields: [witness1Id], references: [id])
  witness2        Employee     @relation("Witness2", fields: [witness2Id], references: [id])
  dispatches      GoldDispatch[]
  
  @@index([siteId])
  @@index([pourDate])
}

model GoldDispatch {
  id              String    @id @default(uuid())
  goldPourId      String
  dispatchDate    DateTime
  courier         String
  vehicle         String?
  destination     String
  sealNumbers     String
  handedOverById  String
  receivedBy      String?
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  goldPour        GoldPour  @relation(fields: [goldPourId], references: [id])
  handedOverBy    Employee  @relation("GoldDispatchHandovers", fields: [handedOverById], references: [id])
  buyerReceipt    BuyerReceipt?
  
  @@index([goldPourId])
}

model BuyerReceipt {
  id              String       @id @default(uuid())
  goldDispatchId  String       @unique
  receiptNumber   String
  receiptDate     DateTime
  assayResult     Float?       // actual purity
  paidAmount      Float
  paymentMethod   String
  paymentChannel  String?
  paymentReference String?
  notes           String?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  goldDispatch    GoldDispatch @relation(fields: [goldDispatchId], references: [id])
  
  @@index([receiptDate])
}

model GoldShiftAllocation {
  id                 String   @id @default(uuid())
  date               DateTime
  shift              ShiftType
  siteId             String
  shiftReportId      String   @unique
  totalWeight        Float
  netWeight          Float
  workerShareWeight  Float
  companyShareWeight Float
  perWorkerWeight    Float
  payCycleWeeks      Int      @default(2)
  createdById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  site         Site        @relation(fields: [siteId], references: [id])
  shiftReport  ShiftReport @relation(fields: [shiftReportId], references: [id])
  createdBy    User        @relation(fields: [createdById], references: [id])
  expenses     GoldShiftExpense[]
  workerShares GoldShiftWorkerShare[]

  @@unique([siteId, date, shift])
  @@index([siteId, date])
}

model GoldShiftExpense {
  id            String   @id @default(uuid())
  allocationId  String
  type          String
  weight        Float

  allocation    GoldShiftAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  @@index([allocationId])
}

model GoldShiftWorkerShare {
  id            String   @id @default(uuid())
  allocationId  String
  employeeId    String
  shareWeight   Float

  allocation    GoldShiftAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  employee      Employee            @relation(fields: [employeeId], references: [id])

  @@unique([allocationId, employeeId])
  @@index([allocationId])
  @@index([employeeId])
}

// ============================================
// PHASE 4: STORES & MAINTENANCE
// ============================================

model StockLocation {
  id        String   @id @default(uuid())
  name      String
  siteId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  
  site      Site     @relation(fields: [siteId], references: [id])
  items     InventoryItem[]
  
  @@index([siteId])
}

model InventoryItem {
  id              String   @id @default(uuid())
  itemCode        String
  name            String
  category        String   // FUEL, SPARES, CONSUMABLES, PPE, REAGENTS
  unit            String   // litres, kg, pieces, etc.
  siteId          String
  locationId      String
  currentStock    Float    @default(0)
  minStock        Float?
  maxStock        Float?
  unitCost        Float?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  site            Site     @relation(fields: [siteId], references: [id])
  location        StockLocation @relation(fields: [locationId], references: [id])
  movements       StockMovement[]
  
  @@unique([siteId, itemCode])
  @@index([siteId])
}

enum MovementType {
  RECEIPT
  ISSUE
  ADJUSTMENT
  TRANSFER
}

model StockMovement {
  id              String       @id @default(uuid())
  itemId          String
  movementType    MovementType
  quantity        Float
  unit            String
  issuedTo        String?      // section/equipment/cost code
  requestedBy     String?
  issuedById      String?
  approvedBy      String?
  notes           String?
  photoUrl        String?
  
  createdAt       DateTime     @default(now())
  
  item            InventoryItem @relation(fields: [itemId], references: [id])
  issuedBy        User?        @relation(fields: [issuedById], references: [id])
  
  @@index([itemId])
  @@index([createdAt])
}

model Equipment {
  id              String   @id @default(uuid())
  equipmentCode   String
  name            String
  category        String   // CRUSHER, MILL, PUMP, VEHICLE, etc.
  siteId          String
  qrCode          String?  @unique
  isActive        Boolean  @default(true)
  
  // Service tracking
  serviceHours    Float?
  serviceDays     Int?
  lastServiceDate DateTime?
  nextServiceDue  DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  site            Site     @relation(fields: [siteId], references: [id])
  workOrders      WorkOrder[]
  
  @@unique([siteId, equipmentCode])
  @@index([siteId])
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model WorkOrder {
  id              String          @id @default(uuid())
  equipmentId     String
  issue           String
  downtimeStart   DateTime
  downtimeEnd     DateTime?
  workDone        String?
  partsUsed       String?         // JSON array
  technicianId    String?
  status          WorkOrderStatus @default(OPEN)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  equipment       Equipment       @relation(fields: [equipmentId], references: [id])
  technician      Employee?       @relation("WorkOrderTechnicians", fields: [technicianId], references: [id])
  
  @@index([equipmentId])
  @@index([status])
}

// ============================================
// PHASE 5: COMPLIANCE
// ============================================

model Permit {
  id              String   @id @default(uuid())
  permitType      String
  permitNumber    String
  siteId          String
  issueDate       DateTime
  expiryDate      DateTime
  responsiblePerson String
  documentUrl     String?
  status          String   @default("ACTIVE") // ACTIVE, EXPIRING_SOON, EXPIRED
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  site            Site     @relation(fields: [siteId], references: [id])
  
  @@index([siteId])
  @@index([expiryDate])
}

model Inspection {
  id              String   @id @default(uuid())
  siteId          String
  inspectionDate  DateTime
  inspectorName   String
  inspectorOrg    String
  findings        String
  actions         String?
  actionsDue      DateTime?
  completedById   String?
  completedAt     DateTime?
  documentUrl     String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  completedBy     User?    @relation(fields: [completedById], references: [id])
  
  @@index([siteId])
}

model Incident {
  id              String   @id @default(uuid())
  siteId          String
  incidentDate    DateTime
  incidentType    String   // INJURY, NEAR_MISS, ENVIRONMENTAL, SECURITY
  severity        String   // LOW, MEDIUM, HIGH, CRITICAL
  description     String
  actionsTaken    String?
  reportedBy      String
  photoUrls       String?  // JSON array
  status          String   @default("OPEN") // OPEN, INVESTIGATING, CLOSED
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  site            Site     @relation(fields: [siteId], references: [id])
  
  @@index([siteId])
  @@index([incidentDate])
}

model TrainingRecord {
  id              String   @id @default(uuid())
  userId          String
  trainingType    String
  trainingDate    DateTime
  expiryDate      DateTime?
  certificateUrl  String?
  trainedBy       String?
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([expiryDate])
}

// ============================================
// NEXTAUTH MODELS
// ============================================

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
}
