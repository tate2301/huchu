model ShiftReport {
  id            String    @id @default(uuid())
  date          DateTime
  shift         String
  siteId        String
  sectionId     String?
  shiftGroupId  String?
  groupLeaderId String
  crewCount     Int
  workType      WorkType

  // Output metrics (flexible per site)
  outputTonnes       Float?
  outputTrips        Int?
  outputWheelbarrows Int?
  metresAdvanced     Float?

  // Safety and handover
  hasIncident   Boolean @default(false)
  incidentNotes String?
  handoverNotes String?

  // Photos (stored as JSON array of URLs)
  photos String? // JSON array

  // Workflow
  status       ReportStatus @default(DRAFT)
  createdById  String
  verifiedById String?
  approvedById String?
  verifiedAt   DateTime?
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site                Site                 @relation(fields: [siteId], references: [id])
  section             Section?             @relation(fields: [sectionId], references: [id])
  shiftGroup          ShiftGroup?          @relation(fields: [shiftGroupId], references: [id])
  groupLeader         Employee             @relation("GroupLeaderReports", fields: [groupLeaderId], references: [id])
  createdBy           User                 @relation("CreatedBy", fields: [createdById], references: [id])
  verifiedBy          User?                @relation("VerifiedBy", fields: [verifiedById], references: [id])
  approvedBy          User?                @relation("ApprovedBy", fields: [approvedById], references: [id])
  downtimeEvents      DowntimeEvent[]
  goldShiftAllocation GoldShiftAllocation?

  @@index([siteId, date])
  @@index([date])
  @@index([shiftGroupId])
}

model DowntimeCode {
  id          String   @id @default(uuid())
  code        String
  description String
  siteId      String? // null = company-wide defaults
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  site   Site?           @relation(fields: [siteId], references: [id])
  events DowntimeEvent[]

  @@index([siteId])
}

model DowntimeEvent {
  id             String   @id @default(uuid())
  shiftReportId  String?
  plantReportId  String?
  downtimeCodeId String
  durationHours  Float
  notes          String?
  createdAt      DateTime @default(now())

  shiftReport  ShiftReport? @relation(fields: [shiftReportId], references: [id])
  plantReport  PlantReport? @relation(fields: [plantReportId], references: [id])
  downtimeCode DowntimeCode @relation(fields: [downtimeCodeId], references: [id])

  @@index([shiftReportId])
  @@index([plantReportId])
}

model Attendance {
  id         String    @id @default(uuid())
  date       DateTime
  siteId     String
  shift      String
  shiftGroupId String?
  shiftLeaderId String?
  shiftLeaderName String?
  employeeId String
  status     String // PRESENT, ABSENT, LATE
  overtime   Float? // hours
  notes      String?
  createdAt  DateTime  @default(now())

  site     Site     @relation(fields: [siteId], references: [id])
  shiftGroup ShiftGroup? @relation(fields: [shiftGroupId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([date, siteId, shift, employeeId])
  @@index([siteId, date])
  @@index([shiftGroupId])
}

model ShiftGroup {
  id             String   @id @default(uuid())
  companyId      String
  siteId         String
  name           String
  code           String?
  leaderEmployeeId String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company    Company              @relation(fields: [companyId], references: [id])
  site       Site                 @relation(fields: [siteId], references: [id])
  leader     Employee             @relation("ShiftGroupLeader", fields: [leaderEmployeeId], references: [id])
  members    ShiftGroupMember[]
  schedules  ShiftGroupSchedule[]
  attendance Attendance[]
  reports    ShiftReport[]

  @@unique([companyId, name])
  @@index([companyId, siteId, isActive])
  @@index([leaderEmployeeId])
}

model ShiftGroupMember {
  id           String   @id @default(uuid())
  shiftGroupId String
  employeeId   String
  isActive     Boolean  @default(true)
  joinedAt     DateTime @default(now())
  leftAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shiftGroup ShiftGroup @relation(fields: [shiftGroupId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@unique([shiftGroupId, employeeId])
  @@index([employeeId, isActive])
}

model ShiftGroupSchedule {
  id           String   @id @default(uuid())
  companyId    String
  siteId       String
  date         DateTime
  shift        String
  shiftGroupId String
  notes        String?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id])
  site       Site       @relation(fields: [siteId], references: [id])
  shiftGroup ShiftGroup @relation(fields: [shiftGroupId], references: [id], onDelete: Cascade)
  createdBy  User       @relation("ShiftGroupScheduleCreatedBy", fields: [createdById], references: [id])

  @@unique([shiftGroupId, date])
  @@index([companyId, date, shift])
  @@index([siteId, date, shift])
  @@index([shiftGroupId])
}

// ============================================
// PHASE 2: PLANT REPORTING
// ============================================

model PlantReport {
  id              String   @id @default(uuid())
  date            DateTime
  siteId          String
  tonnesFed       Float?
  tonnesProcessed Float?
  runHours        Float?

  // Consumables
  dieselUsed    Float?
  grindingMedia Float?
  reagentsUsed  Float?
  waterUsed     Float?

  // Gold recovered (if poured)
  goldRecovered Float?

  notes        String?
  reportedById String
  status       ReportStatus @default(DRAFT)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  site           Site            @relation(fields: [siteId], references: [id])
  reportedBy     User            @relation(fields: [reportedById], references: [id])
  downtimeEvents DowntimeEvent[]

  @@index([siteId, date])
}

// ============================================
// PHASE 3: GOLD CONTROL
// ============================================

model GoldPrice {
  id              String   @id @default(uuid())
  companyId       String
  effectiveDate   DateTime
  priceUsdPerGram Float
  note            String?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, effectiveDate])
  @@index([companyId, effectiveDate])
}

model GoldPour {
  id              String   @id @default(uuid())
  pourBarId       String   @unique
  pourDate        DateTime
  siteId          String
  sourceType      GoldLotSource @default(PRODUCTION)
  grossWeight     Float
  estimatedPurity Float?
  witness1Id      String
  witness2Id      String
  storageLocation String
  notes           String?
  goldPriceUsdPerGram Float?
  valuationDate       DateTime?
  valueUsd            Float?

  // Audit trail
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  corrections String? // JSON log of corrections

  site       Site           @relation(fields: [siteId], references: [id])
  witness1   Employee       @relation("Witness1", fields: [witness1Id], references: [id])
  witness2   Employee       @relation("Witness2", fields: [witness2Id], references: [id])
  purchase   GoldPurchase?
  dispatches GoldDispatch[]
  receipts   BuyerReceipt[]

  @@index([siteId])
  @@index([pourDate])
}

enum GoldLotSource {
  PRODUCTION
  PURCHASE_PUBLIC
}

enum GoldSellerType {
  EMPLOYEE
  EXTERNAL
}

model GoldPurchase {
  id               String         @id @default(uuid())
  companyId        String
  siteId           String
  goldPourId       String         @unique
  purchaseNumber   String
  purchaseDate     DateTime
  sellerType       GoldSellerType @default(EXTERNAL)
  sellerEmployeeId String?
  sellerName       String
  sellerPhone      String
  grossWeight      Float
  estimatedPurity  Float?
  storageLocation  String
  receiver1Id      String
  receiver2Id      String
  paidAmount       Float
  currency         String         @default("USD")
  paymentMethod    String
  paymentChannel   String?
  paymentReference String?
  notes            String?
  createdById      String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site           Site      @relation(fields: [siteId], references: [id])
  goldPour       GoldPour  @relation(fields: [goldPourId], references: [id])
  sellerEmployee Employee? @relation("GoldPurchaseSeller", fields: [sellerEmployeeId], references: [id])
  receiver1      Employee  @relation("GoldPurchaseReceiver1", fields: [receiver1Id], references: [id])
  receiver2      Employee  @relation("GoldPurchaseReceiver2", fields: [receiver2Id], references: [id])
  createdBy      User      @relation("GoldPurchaseCreatedBy", fields: [createdById], references: [id])

  @@unique([companyId, purchaseNumber])
  @@index([companyId, purchaseDate])
  @@index([siteId, purchaseDate])
  @@index([sellerEmployeeId])
  @@index([receiver1Id])
  @@index([receiver2Id])
}

model GoldDispatch {
  id             String   @id @default(uuid())
  goldPourId     String
  dispatchDate   DateTime
  courier        String
  vehicle        String?
  destination    String
  sealNumbers    String
  handedOverById String
  receivedBy     String?
  notes          String?
  goldPriceUsdPerGram Float?
  valuationDate       DateTime?
  valueUsd            Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goldPour     GoldPour      @relation(fields: [goldPourId], references: [id])
  handedOverBy Employee      @relation("GoldDispatchHandovers", fields: [handedOverById], references: [id])
  buyerReceipt BuyerReceipt?

  @@index([goldPourId])
}

model BuyerReceipt {
  id               String   @id @default(uuid())
  goldDispatchId   String?  @unique
  goldPourId       String?
  receiptNumber    String
  receiptDate      DateTime
  assayResult      Float? // actual purity
  paidAmount       Float
  paymentMethod    String
  paymentChannel   String?
  paymentReference String?
  notes            String?
  goldPriceUsdPerGram Float?
  valuationDate       DateTime?
  paidValueUsd        Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goldDispatch GoldDispatch? @relation(fields: [goldDispatchId], references: [id])
  goldPour     GoldPour?     @relation(fields: [goldPourId], references: [id])

  @@index([goldPourId])
  @@index([receiptDate])
}

model GoldShiftAllocation {
  id                 String    @id @default(uuid())
  date               DateTime
  shift              String
  siteId             String
  shiftReportId      String    @unique
  totalWeight        Float
  netWeight          Float
  splitMode          GoldShiftSplitMode @default(DEFAULT_50_50)
  workerShareOverrideWeight Float?
  splitOverrideReason String?
  workerShareWeight  Float
  companyShareWeight Float
  perWorkerWeight    Float
  goldPriceUsdPerGram Float?
  valuationDate       DateTime?
  totalWeightValueUsd Float?
  netWeightValueUsd   Float?
  workerShareValueUsd Float?
  companyShareValueUsd Float?
  perWorkerValueUsd   Float?
  payCycleWeeks      Int       @default(2)
  workflowStatus     WorkflowStatus @default(DRAFT)
  createdById        String
  submittedById      String?
  approvedById       String?
  submittedAt        DateTime?
  approvedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  site         Site                   @relation(fields: [siteId], references: [id])
  shiftReport  ShiftReport            @relation(fields: [shiftReportId], references: [id])
  createdBy    User                   @relation("GoldShiftAllocationCreatedBy", fields: [createdById], references: [id])
  submittedBy  User?                  @relation("GoldShiftAllocationSubmittedBy", fields: [submittedById], references: [id])
  approvedBy   User?                  @relation("GoldShiftAllocationApprovedBy", fields: [approvedById], references: [id])
  expenses     GoldShiftExpense[]
  workerShares GoldShiftWorkerShare[]

  @@unique([siteId, date, shift])
  @@index([siteId, date])
  @@index([workflowStatus])
}

model GoldShiftExpense {
  id           String @id @default(uuid())
  allocationId String
  type         String
  weight       Float

  allocation GoldShiftAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  @@index([allocationId])
}

model GoldShiftWorkerShare {
  id           String @id @default(uuid())
  allocationId String
  employeeId   String
  shareWeight  Float
  shareValueUsd Float?

  allocation GoldShiftAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  employee   Employee            @relation(fields: [employeeId], references: [id])

  @@unique([allocationId, employeeId])
  @@index([allocationId])
  @@index([employeeId])
}

// ============================================
// PHASE 4: STORES & MAINTENANCE
// ============================================

model StockLocation {
  id        String   @id @default(uuid())
  code      String
  name      String
  siteId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  site  Site            @relation(fields: [siteId], references: [id])
  items InventoryItem[]
  equipment Equipment[]
  incomingMovements StockMovement[] @relation("StockMovementDestination")

  @@index([siteId])
  @@unique([siteId, code])
}

model InventoryItem {
  id           String @id @default(uuid())
  itemCode     String
  name         String
  category     String // FUEL, SPARES, CONSUMABLES, PPE, REAGENTS
  unit         String // litres, kg, pieces, etc.
  siteId       String
  locationId   String
  currentStock Float  @default(0)
  minStock     Float?
  maxStock     Float?
  unitCost     Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site      Site            @relation(fields: [siteId], references: [id])
  location  StockLocation   @relation(fields: [locationId], references: [id])
  movements StockMovement[]

  @@unique([siteId, itemCode])
  @@index([siteId])
}

enum MovementType {
  RECEIPT
  ISSUE
  ADJUSTMENT
  TRANSFER
}

model StockMovement {
  id           String       @id @default(uuid())
  referenceId  String       @unique
  itemId       String
  toLocationId String?
  movementType MovementType
  quantity     Float
  unit         String
  issuedTo     String? // section/equipment/cost code
  requestedBy  String?
  issuedById   String?
  approvedBy   String?
  notes        String?
  photoUrl     String?

  createdAt DateTime @default(now())

  item     InventoryItem @relation(fields: [itemId], references: [id])
  toLocation StockLocation? @relation("StockMovementDestination", fields: [toLocationId], references: [id])
  issuedBy User?         @relation(fields: [issuedById], references: [id])

  @@index([itemId])
  @@index([toLocationId])
  @@index([createdAt])
}

model Equipment {
  id            String  @id @default(uuid())
  equipmentCode String
  name          String
  category      String // CRUSHER, MILL, PUMP, VEHICLE, etc.
  siteId        String
  locationId    String
  numberOfItems Int     @default(1)
  qrCode        String? @unique
  isActive      Boolean @default(true)

  // Service tracking
  serviceHours    Float?
  serviceDays     Int?
  lastServiceDate DateTime?
  nextServiceDue  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site       Site          @relation(fields: [siteId], references: [id])
  location   StockLocation @relation(fields: [locationId], references: [id])
  workOrders WorkOrder[]

  @@unique([siteId, equipmentCode])
  @@index([siteId])
  @@index([locationId])
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model WorkOrder {
  id            String          @id @default(uuid())
  equipmentId   String
  issue         String
  downtimeStart DateTime
  downtimeEnd   DateTime?
  workDone      String?
  partsUsed     String? // JSON array
  partsCost     Float?  @default(0)
  laborCost     Float?  @default(0)
  technicianId  String?
  status        WorkOrderStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipment  Equipment @relation(fields: [equipmentId], references: [id])
  technician Employee? @relation("WorkOrderTechnicians", fields: [technicianId], references: [id])

  @@index([equipmentId])
  @@index([status])
}

// ============================================
// PHASE 6: ACCOUNTING
// ============================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
}

enum AccountingPeriodLockPolicy {
  STRICT
  MANAGER_OVERRIDE
  SOFT_WARN
}

enum JournalStatus {
  DRAFT
  POSTED
  REVERSED
  VOIDED
}

enum PostingDirection {
  DEBIT
  CREDIT
}

enum PostingBasis {
  AMOUNT
  NET
  TAX
  GROSS
  DEDUCTIONS
  ALLOWANCES
}

enum AllocationType {
  PERCENT
  FIXED
}

enum AccountingSourceType {
  MANUAL
  STOCK_RECEIPT
  STOCK_ISSUE
  STOCK_ADJUSTMENT
  STOCK_TRANSFER
  PAYROLL_RUN
  PAYROLL_DISBURSEMENT
  GOLD_PURCHASE
  GOLD_RECEIPT
  GOLD_DISPATCH
  SALES_INVOICE
  SALES_RECEIPT
  SALES_CREDIT_NOTE
  SALES_WRITE_OFF
  PURCHASE_BILL
  PURCHASE_PAYMENT
  PURCHASE_DEBIT_NOTE
  PURCHASE_WRITE_OFF
  BANK_TRANSACTION
  MAINTENANCE_COMPLETION
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOIDED
}

enum BillStatus {
  DRAFT
  RECEIVED
  PAID
  VOIDED
}

enum FiscalReceiptStatus {
  PENDING
  SUCCESS
  FAILED
  VOIDED
}

enum BudgetStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum NoteStatus {
  DRAFT
  ISSUED
  VOIDED
}

enum WriteOffStatus {
  POSTED
  VOIDED
}

enum ReconciliationStatus {
  OPEN
  CLOSED
  VOIDED
}

model AccountingSettings {
  id                   String   @id @default(uuid())
  companyId            String   @unique
  baseCurrency         String   @default("USD")
  fiscalYearStartMonth Int      @default(1)
  periodLockPolicy     AccountingPeriodLockPolicy @default(MANAGER_OVERRIDE)
  legalName            String?
  tradingName          String?
  vatNumber            String?
  taxNumber            String?
  address              String?
  phone                String?
  email                String?
  defaultTaxCodeId     String?
  defaultBankAccountId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company            Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  defaultTaxCode     TaxCode?      @relation("DefaultTaxCode", fields: [defaultTaxCodeId], references: [id])
  defaultBankAccount BankAccount? @relation("DefaultBankAccount", fields: [defaultBankAccountId], references: [id])
}

model ChartOfAccount {
  id            String     @id @default(uuid())
  companyId     String
  code          String
  name          String
  type          AccountType
  category      String?
  description   String?
  isActive      Boolean    @default(true)
  systemManaged Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalLines   JournalLine[]
  postingLines   PostingRuleLine[]
  budgetLines    BudgetLine[]

  @@unique([companyId, code])
  @@index([companyId, type])
}

model AccountingPeriod {
  id         String                @id @default(uuid())
  companyId  String
  startDate  DateTime
  endDate    DateTime
  status     AccountingPeriodStatus @default(OPEN)
  closedAt   DateTime?
  closedById String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  closedBy User?          @relation("AccountingPeriodClosedBy", fields: [closedById], references: [id])
  journals JournalEntry[]

  @@index([companyId, startDate, endDate])
}

model JournalEntry {
  id          String              @id @default(uuid())
  companyId   String
  entryNumber Int
  entryDate   DateTime
  description String
  status      JournalStatus       @default(DRAFT)
  periodId    String?
  sourceType  AccountingSourceType @default(MANUAL)
  sourceId    String?
  createdById String
  postedById  String?
  postedAt    DateTime?
  reversedById String?
  reversedAt  DateTime?
  voidedById  String?
  voidedAt    DateTime?
  periodOverrideReason String?
  periodOverrideById String?
  periodOverrideAt DateTime?
  reversalOfEntryId String? @unique
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period     AccountingPeriod? @relation(fields: [periodId], references: [id])
  createdBy  User             @relation("JournalEntryCreatedBy", fields: [createdById], references: [id])
  postedBy   User?            @relation("JournalEntryPostedBy", fields: [postedById], references: [id])
  reversedBy User?            @relation("JournalEntryReversedBy", fields: [reversedById], references: [id])
  voidedBy   User?            @relation("JournalEntryVoidedBy", fields: [voidedById], references: [id])
  periodOverrideBy User?      @relation("JournalEntryPeriodOverrideBy", fields: [periodOverrideById], references: [id])
  reversalOfEntry JournalEntry? @relation("JournalEntryReversal", fields: [reversalOfEntryId], references: [id])
  reversalEntry JournalEntry? @relation("JournalEntryReversal")
  lines      JournalLine[]

  @@unique([companyId, entryNumber])
  @@unique([companyId, sourceType, sourceId])
  @@index([companyId, entryDate])
}

enum AccountingIntegrationStatus {
  PENDING
  POSTED
  FAILED
  IGNORED
}

model AccountingIntegrationEvent {
  id               String                     @id @default(uuid())
  companyId        String
  sourceDomain     String
  sourceAction     String
  sourceType       AccountingSourceType?
  sourceId         String?
  eventKey         String                     @unique
  entryDate        DateTime?
  description      String?
  amount           Float?
  netAmount        Float?
  taxAmount        Float?
  grossAmount      Float?
  deductionsAmount Float?
  allowancesAmount Float?
  currency         String?
  payloadJson      String?
  status           AccountingIntegrationStatus @default(PENDING)
  attemptCount     Int                        @default(0)
  nextRetryAt      DateTime?
  lastError        String?
  journalEntryId   String?
  createdById      String?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status, nextRetryAt])
  @@index([companyId, sourceType, sourceId])
}

model JournalLine {
  id           String   @id @default(uuid())
  entryId      String
  accountId    String
  debit        Float    @default(0)
  credit       Float    @default(0)
  memo         String?
  costCenterId String?
  createdAt    DateTime @default(now())

  entry      JournalEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account    ChartOfAccount @relation(fields: [accountId], references: [id])
  costCenter CostCenter?   @relation(fields: [costCenterId], references: [id])

  @@index([entryId])
  @@index([accountId])
}

model PostingRule {
  id          String              @id @default(uuid())
  companyId   String
  name        String
  sourceType  AccountingSourceType
  description String?
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   PostingRuleLine[]

  @@unique([companyId, sourceType])
}

model PostingRuleLine {
  id              String          @id @default(uuid())
  ruleId          String
  accountId       String
  direction       PostingDirection
  basis           PostingBasis     @default(AMOUNT)
  allocationType  AllocationType   @default(PERCENT)
  allocationValue Float           @default(100)
  taxCodeId       String?
  createdAt       DateTime         @default(now())

  rule    PostingRule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  account ChartOfAccount @relation(fields: [accountId], references: [id])
  taxCode TaxCode?      @relation(fields: [taxCodeId], references: [id])

  @@index([ruleId])
}

model TaxCode {
  id          String   @id @default(uuid())
  companyId   String
  code        String
  name        String
  rate        Float    @default(0)
  type        String   @default("VAT") // VAT, WITHHOLDING, OTHER
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceLines SalesInvoiceLine[]
  billLines PurchaseBillLine[]
  creditNoteLines CreditNoteLine[]
  debitNoteLines DebitNoteLine[]
  postingLines PostingRuleLine[]
  defaultForSettings AccountingSettings[] @relation("DefaultTaxCode")

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@index([companyId, code, effectiveFrom, effectiveTo])
}

model Customer {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  taxNumber   String?
  vatNumber   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices SalesInvoice[]

  @@index([companyId, isActive])
}

model Vendor {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  taxNumber   String?
  vatNumber   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bills   PurchaseBill[]

  @@index([companyId, isActive])
}

model SalesInvoice {
  id             String         @id @default(uuid())
  companyId      String
  customerId     String
  invoiceNumber  String
  invoiceDate    DateTime
  dueDate        DateTime?
  status         InvoiceStatus  @default(DRAFT)
  currency       String         @default("USD")
  subTotal       Float          @default(0)
  taxTotal       Float          @default(0)
  total          Float          @default(0)
  amountPaid     Float          @default(0)
  creditTotal    Float          @default(0)
  writeOffTotal  Float          @default(0)
  notes          String?
  // Fiscal receipt relation is managed via FiscalReceipt.invoiceId
  fiscalStatus   FiscalReceiptStatus? @default(PENDING)
  createdById    String?
  issuedById     String?
  issuedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer      Customer       @relation(fields: [customerId], references: [id])
  lines         SalesInvoiceLine[]
  receipts      SalesReceipt[]
  fiscalReceipt FiscalReceipt? @relation("SalesInvoiceFiscalReceipt")
  creditNotes   CreditNote[]
  writeOffs     SalesWriteOff[]
  createdBy     User?          @relation("SalesInvoiceCreatedBy", fields: [createdById], references: [id])
  issuedBy      User?          @relation("SalesInvoiceIssuedBy", fields: [issuedById], references: [id])

  @@unique([companyId, invoiceNumber])
  @@index([companyId, status])
}

model SalesInvoiceLine {
  id          String   @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  taxCodeId   String?
  taxRate     Float    @default(0)
  taxAmount   Float    @default(0)
  lineTotal   Float    @default(0)
  createdAt   DateTime @default(now())

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  taxCode TaxCode?     @relation(fields: [taxCodeId], references: [id])

  @@index([invoiceId])
}

model SalesReceipt {
  id            String   @id @default(uuid())
  companyId     String
  invoiceId     String?
  receiptNumber String
  receivedAt    DateTime
  amount        Float
  method        String
  reference     String?
  bankAccountId String?
  createdById   String?
  createdAt     DateTime @default(now())

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice     SalesInvoice?  @relation(fields: [invoiceId], references: [id])
  bankAccount BankAccount?   @relation(fields: [bankAccountId], references: [id])
  createdBy   User?          @relation("SalesReceiptCreatedBy", fields: [createdById], references: [id])

  @@unique([companyId, receiptNumber])
}

model CreditNote {
  id           String     @id @default(uuid())
  companyId    String
  invoiceId    String
  noteNumber   String
  noteDate     DateTime
  status       NoteStatus @default(DRAFT)
  currency     String     @default("USD")
  subTotal     Float      @default(0)
  taxTotal     Float      @default(0)
  total        Float      @default(0)
  reason       String?
  createdById  String?
  issuedById   String?
  issuedAt     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lines     CreditNoteLine[]
  createdBy User?        @relation("CreditNoteCreatedBy", fields: [createdById], references: [id])
  issuedBy  User?        @relation("CreditNoteIssuedBy", fields: [issuedById], references: [id])

  @@unique([companyId, noteNumber])
  @@index([companyId, status])
}

model CreditNoteLine {
  id          String   @id @default(uuid())
  noteId      String
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  taxCodeId   String?
  taxRate     Float    @default(0)
  taxAmount   Float    @default(0)
  lineTotal   Float    @default(0)
  createdAt   DateTime @default(now())

  note    CreditNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  taxCode TaxCode?   @relation(fields: [taxCodeId], references: [id])

  @@index([noteId])
}

model SalesWriteOff {
  id          String        @id @default(uuid())
  companyId   String
  invoiceId   String
  amount      Float
  reason      String?
  status      WriteOffStatus @default(POSTED)
  createdById String?
  createdAt   DateTime      @default(now())

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("SalesWriteOffCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, invoiceId])
}

model PurchaseBill {
  id            String     @id @default(uuid())
  companyId     String
  vendorId      String
  billNumber    String
  billDate      DateTime
  dueDate       DateTime?
  status        BillStatus @default(DRAFT)
  currency      String     @default("USD")
  subTotal      Float      @default(0)
  taxTotal      Float      @default(0)
  total         Float      @default(0)
  amountPaid    Float      @default(0)
  debitNoteTotal Float     @default(0)
  writeOffTotal Float      @default(0)
  notes         String?
  createdById   String?
  issuedById    String?
  issuedAt      DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor   Vendor          @relation(fields: [vendorId], references: [id])
  lines    PurchaseBillLine[]
  payments PurchasePayment[]
  debitNotes DebitNote[]
  writeOffs  PurchaseWriteOff[]
  createdBy User?          @relation("PurchaseBillCreatedBy", fields: [createdById], references: [id])
  issuedBy  User?          @relation("PurchaseBillIssuedBy", fields: [issuedById], references: [id])

  @@unique([companyId, billNumber])
  @@index([companyId, status])
}

model PurchaseBillLine {
  id          String   @id @default(uuid())
  billId      String
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  taxCodeId   String?
  taxRate     Float    @default(0)
  taxAmount   Float    @default(0)
  lineTotal   Float    @default(0)
  createdAt   DateTime @default(now())

  bill    PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  taxCode TaxCode?     @relation(fields: [taxCodeId], references: [id])

  @@index([billId])
}

model PurchasePayment {
  id            String   @id @default(uuid())
  companyId     String
  billId        String?
  paymentNumber String
  paidAt        DateTime
  amount        Float
  method        String
  reference     String?
  bankAccountId String?
  createdById   String?
  createdAt     DateTime @default(now())

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bill        PurchaseBill?  @relation(fields: [billId], references: [id])
  bankAccount BankAccount?   @relation(fields: [bankAccountId], references: [id])
  createdBy   User?          @relation("PurchasePaymentCreatedBy", fields: [createdById], references: [id])

  @@unique([companyId, paymentNumber])
}

model DebitNote {
  id           String     @id @default(uuid())
  companyId    String
  billId       String
  noteNumber   String
  noteDate     DateTime
  status       NoteStatus @default(DRAFT)
  currency     String     @default("USD")
  subTotal     Float      @default(0)
  taxTotal     Float      @default(0)
  total        Float      @default(0)
  reason       String?
  createdById  String?
  issuedById   String?
  issuedAt     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bill      PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  lines     DebitNoteLine[]
  createdBy User?        @relation("DebitNoteCreatedBy", fields: [createdById], references: [id])
  issuedBy  User?        @relation("DebitNoteIssuedBy", fields: [issuedById], references: [id])

  @@unique([companyId, noteNumber])
  @@index([companyId, status])
}

model DebitNoteLine {
  id          String   @id @default(uuid())
  noteId      String
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  taxCodeId   String?
  taxRate     Float    @default(0)
  taxAmount   Float    @default(0)
  lineTotal   Float    @default(0)
  createdAt   DateTime @default(now())

  note    DebitNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  taxCode TaxCode?  @relation(fields: [taxCodeId], references: [id])

  @@index([noteId])
}

model PurchaseWriteOff {
  id          String        @id @default(uuid())
  companyId   String
  billId      String
  amount      Float
  reason      String?
  status      WriteOffStatus @default(POSTED)
  createdById String?
  createdAt   DateTime      @default(now())

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bill      PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("PurchaseWriteOffCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, billId])
}

model BankAccount {
  id             String   @id @default(uuid())
  companyId      String
  name           String
  bankName       String?
  accountNumber  String?
  currency       String   @default("USD")
  openingBalance Float    @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions   BankTransaction[]
  salesReceipts  SalesReceipt[]
  purchasePayments PurchasePayment[]
  reconciliations BankReconciliation[]
  defaultForSettings AccountingSettings[] @relation("DefaultBankAccount")

  @@index([companyId, isActive])
}

model BankTransaction {
  id           String   @id @default(uuid())
  companyId    String
  bankAccountId String
  txnDate      DateTime
  description  String
  reference    String?
  amount       Float
  direction    PostingDirection
  sourceType   AccountingSourceType?
  sourceId     String?
  reconciliationId String?
  reconciledAt DateTime?
  createdAt    DateTime @default(now())

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])
  reconciliation BankReconciliation? @relation(fields: [reconciliationId], references: [id])
  matchedStatementLines BankStatementLine[]

  @@index([companyId, txnDate])
}

model BankReconciliation {
  id               String               @id @default(uuid())
  companyId        String
  bankAccountId    String
  startDate        DateTime
  endDate          DateTime
  statementBalance Float               @default(0)
  status           ReconciliationStatus @default(OPEN)
  createdById      String?
  closedById       String?
  closedAt         DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankAccount    BankAccount     @relation(fields: [bankAccountId], references: [id])
  transactions   BankTransaction[]
  statementLines BankStatementLine[]
  createdBy      User?           @relation("BankReconciliationCreatedBy", fields: [createdById], references: [id])
  closedBy       User?           @relation("BankReconciliationClosedBy", fields: [closedById], references: [id])

  @@index([companyId, bankAccountId, status])
}

model BankStatementLine {
  id                   String   @id @default(uuid())
  reconciliationId     String
  txnDate              DateTime
  description          String
  reference            String?
  amount               Float
  direction            PostingDirection
  matchedTransactionId String?
  createdAt            DateTime @default(now())

  reconciliation    BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  matchedTransaction BankTransaction?  @relation(fields: [matchedTransactionId], references: [id])

  @@index([reconciliationId])
}

model VatReturnSummary {
  id          String   @id @default(uuid())
  companyId   String
  periodStart DateTime
  periodEnd   DateTime
  outputTax   Float    @default(0)
  inputTax    Float    @default(0)
  netTax      Float    @default(0)
  createdById String?
  createdAt   DateTime @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("VatReturnCreatedBy", fields: [createdById], references: [id])

  @@index([companyId, periodStart, periodEnd])
}

enum DepreciationMethod {
  STRAIGHT_LINE
}

model FixedAsset {
  id              String   @id @default(uuid())
  companyId       String
  assetCode       String
  name            String
  category        String?
  acquisitionDate DateTime
  cost            Float
  salvageValue    Float    @default(0)
  usefulLifeMonths Int     @default(36)
  depreciationMethod DepreciationMethod @default(STRAIGHT_LINE)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, assetCode])
  @@index([companyId, isActive])
}

model Budget {
  id          String       @id @default(uuid())
  companyId   String
  name        String
  startDate   DateTime
  endDate     DateTime
  status      BudgetStatus @default(DRAFT)
  totalAmount Float        @default(0)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   BudgetLine[]

  @@index([companyId, status])
}

model BudgetLine {
  id           String   @id @default(uuid())
  companyId    String
  budgetId     String
  accountId    String
  costCenterId String?
  amount       Float
  createdAt    DateTime @default(now())

  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  budget     Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account    ChartOfAccount @relation(fields: [accountId], references: [id])
  costCenter CostCenter?    @relation(fields: [costCenterId], references: [id])

  @@index([companyId])
  @@index([budgetId])
}

model CostCenter {
  id         String   @id @default(uuid())
  companyId  String
  code       String
  name       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]
  budgetLines  BudgetLine[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
}

model CurrencyRate {
  id            String   @id @default(uuid())
  companyId     String
  baseCurrency  String
  quoteCurrency String
  rate          Float
  effectiveDate DateTime
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, effectiveDate])
}

model FiscalisationProviderConfig {
  id          String   @id @default(uuid())
  companyId   String
  providerKey String
  apiBaseUrl  String?
  username    String?
  password    String?
  apiToken    String?
  deviceId    String?
  metadataJson String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, providerKey])
  @@index([companyId, isActive])
}

model FiscalReceipt {
  id            String   @id @default(uuid())
  companyId     String
  invoiceId     String?
  receiptNumber String?
  fiscalNumber  String?
  status        FiscalReceiptStatus @default(PENDING)
  issuedAt      DateTime?
  qrCodeData    String?
  signature     String?
  providerKey   String?
  rawResponseJson String?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice SalesInvoice? @relation("SalesInvoiceFiscalReceipt", fields: [invoiceId], references: [id])

  @@unique([invoiceId])
  @@index([companyId, status])
}

// ============================================
// PHASE 5: COMPLIANCE
// ============================================

model Permit {
  id                String   @id @default(uuid())
  permitType        String
  permitNumber      String
  siteId            String
  issueDate         DateTime
  expiryDate        DateTime
  responsiblePerson String
  documentUrl       String?
  status            String   @default("ACTIVE") // ACTIVE, EXPIRING_SOON, EXPIRED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@index([expiryDate])
}

model Inspection {
  id             String    @id @default(uuid())
  siteId         String
  inspectionDate DateTime
  inspectorName  String
  inspectorOrg   String
  findings       String
  actions        String?
  actionsDue     DateTime?
  completedById  String?
  completedAt    DateTime?
  documentUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site        Site  @relation(fields: [siteId], references: [id], onDelete: Restrict)
  completedBy User? @relation(fields: [completedById], references: [id])

  @@index([siteId])
}

model Incident {
  id           String   @id @default(uuid())
  siteId       String
  incidentDate DateTime
  incidentType String // INJURY, NEAR_MISS, ENVIRONMENTAL, SECURITY
  severity     String // LOW, MEDIUM, HIGH, CRITICAL
  description  String
  actionsTaken String?
  reportedBy   String
  photoUrls    String? // JSON array
  status       String   @default("OPEN") // OPEN, INVESTIGATING, CLOSED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site             Site         @relation(fields: [siteId], references: [id])
  linkedHrIncidents HrIncident[] @relation("SourceOpsIncident")

  @@index([siteId])
  @@index([incidentDate])
}

model HrIncident {
  id               String             @id @default(uuid())
  companyId        String
  employeeId       String
  siteId           String?
  sourceIncidentId String?
  incidentDate     DateTime
  category         HrIncidentCategory
  severity         HrIncidentSeverity @default(MEDIUM)
  status           HrIncidentStatus   @default(OPEN)
  title            String
  description      String
  investigationNotes String?
  reportedById     String
  resolvedById     String?
  resolvedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  company        Company               @relation(fields: [companyId], references: [id])
  employee       Employee              @relation(fields: [employeeId], references: [id])
  site           Site?                 @relation(fields: [siteId], references: [id])
  sourceIncident Incident?             @relation("SourceOpsIncident", fields: [sourceIncidentId], references: [id])
  reportedBy     User                  @relation("HrIncidentReportedBy", fields: [reportedById], references: [id])
  resolvedBy     User?                 @relation("HrIncidentResolvedBy", fields: [resolvedById], references: [id])
  actions        DisciplinaryAction[]

  @@index([companyId, status, incidentDate])
  @@index([employeeId, incidentDate])
  @@index([siteId])
  @@index([sourceIncidentId])
  @@index([reportedById])
}

model DisciplinaryAction {
  id            String                   @id @default(uuid())
  companyId     String
  incidentId    String?
  employeeId    String
  actionType    DisciplinaryActionType
  status        DisciplinaryActionStatus @default(DRAFT)
  summary       String
  notes         String?
  effectiveDate DateTime?
  penaltyAmount Float                    @default(0)
  penaltyCurrency String                 @default("USD")
  penaltyStatus PenaltyStatus            @default(NONE)
  createdById   String
  submittedById String?
  approvedById  String?
  appliedById   String?
  submittedAt   DateTime?
  approvedAt    DateTime?
  appliedAt     DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  company     Company     @relation(fields: [companyId], references: [id])
  incident    HrIncident? @relation(fields: [incidentId], references: [id])
  employee    Employee    @relation(fields: [employeeId], references: [id])
  createdBy   User        @relation("DisciplinaryActionCreatedBy", fields: [createdById], references: [id])
  submittedBy User?       @relation("DisciplinaryActionSubmittedBy", fields: [submittedById], references: [id])
  approvedBy  User?       @relation("DisciplinaryActionApprovedBy", fields: [approvedById], references: [id])
  appliedBy   User?       @relation("DisciplinaryActionAppliedBy", fields: [appliedById], references: [id])

  @@index([companyId, status, createdAt])
  @@index([employeeId, createdAt])
  @@index([incidentId])
  @@index([actionType, penaltyStatus])
}

model TrainingRecord {
  id             String    @id @default(uuid())
  userId         String
  trainingType   String
  trainingDate   DateTime
  expiryDate     DateTime?
  certificateUrl String?
  trainedBy      String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiryDate])
}

// ============================================
// NEXTAUTH MODELS
// ============================================

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// CCTV / SURVEILLANCE INTEGRATION
// ============================================

model NVR {
  id            String    @id @default(uuid())
  name          String
  ipAddress     String
  port          Int       @default(554) // RTSP port
  httpPort      Int       @default(80) // ISAPI port
  username      String
  password      String // Encrypted in production
  siteId        String
  manufacturer  String    @default("Hikvision")
  model         String?
  firmware      String?
  isActive      Boolean   @default(true)
  isOnline      Boolean   @default(false)
  lastHeartbeat DateTime?

  // Network settings
  rtspPort     Int     @default(554)
  isapiEnabled Boolean @default(true)
  onvifEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site    Site        @relation(fields: [siteId], references: [id])
  cameras Camera[]
  events  CCTVEvent[]

  @@index([siteId])
  @@index([ipAddress])
}

model Camera {
  id            String @id @default(uuid())
  name          String
  channelNumber Int
  nvrId         String
  siteId        String

  // Location/Area
  area        String // "Gate", "Gold Room", "Crusher", "Processing"
  description String?

  // Stream configuration
  mainStreamId String? // e.g., "101" for channel 1 main
  subStreamId  String? // e.g., "102" for channel 1 sub

  // Camera capabilities
  hasPTZ          Boolean @default(false)
  hasAudio        Boolean @default(false)
  hasMotionDetect Boolean @default(true)
  hasLineDetect   Boolean @default(false)
  isActive        Boolean @default(true)

  // Status
  isOnline    Boolean   @default(false)
  isRecording Boolean   @default(true)
  lastSeen    DateTime?

  // Business context
  isHighSecurity Boolean @default(false) // e.g., gold room cameras
  requiredUptime Float? // percentage

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nvr             NVR               @relation(fields: [nvrId], references: [id])
  site            Site              @relation(fields: [siteId], references: [id])
  events          CCTVEvent[]
  streamSessions  StreamSession[]
  playbackRecords PlaybackRecord[]
  accessLogs      CameraAccessLog[]

  @@unique([nvrId, channelNumber])
  @@index([siteId])
  @@index([nvrId])
  @@index([area])
}

enum CCTVEventType {
  MOTION_DETECTION
  LINE_CROSSING
  INTRUSION
  VIDEO_LOSS
  DISK_FULL
  DISK_ERROR
  NETWORK_DISCONNECTED
  ILLEGAL_ACCESS
  ALARM_INPUT
  TAMPERING
}

enum EventSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StreamProtocol {
  WEBRTC
  HLS
}

enum StreamSessionStatus {
  ACTIVE
  STOPPED
  FAILED
}

model CCTVEvent {
  id        String        @id @default(uuid())
  nvrId     String?
  cameraId  String?
  eventType CCTVEventType
  severity  EventSeverity @default(MEDIUM)
  eventTime DateTime

  // Event details
  title       String
  description String?
  snapshotUrl String? // URL to event snapshot

  // Context
  linkedIncidentId String? // Link to Incident model if escalated

  // Status
  isAcknowledged Boolean   @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?
  notes          String?

  createdAt DateTime @default(now())

  nvr    NVR?    @relation(fields: [nvrId], references: [id])
  camera Camera? @relation(fields: [cameraId], references: [id])

  @@index([eventTime])
  @@index([cameraId])
  @@index([eventType])
  @@index([isAcknowledged])
}

model StreamSession {
  id         String              @id @default(uuid())
  cameraId   String
  siteId     String
  userId     String
  streamType String              @default("sub")
  protocol   StreamProtocol
  status     StreamSessionStatus @default(ACTIVE)
  playUrl    String?
  purpose    String?
  clientMeta String?
  startedAt  DateTime            @default(now())
  endedAt    DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  camera Camera @relation(fields: [cameraId], references: [id])
  site   Site   @relation(fields: [siteId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([cameraId, status])
  @@index([siteId, startedAt])
  @@index([userId, startedAt])
}

model PlaybackRecord {
  id        String   @id @default(uuid())
  cameraId  String
  startTime DateTime
  endTime   DateTime
  fileSize  Int? // in MB

  // Playback access
  playbackUri   String? // RTSP URI for playback
  recordingType String  @default("CONTINUOUS") // CONTINUOUS, EVENT, MANUAL

  // Metadata
  duration   Int? // in seconds
  hasAudio   Boolean @default(false)
  resolution String? // e.g., "1920x1080"

  // Access tracking
  requestedBy String? // User who requested playback
  purpose     String? // "Incident review", "Audit", etc.

  createdAt DateTime @default(now())

  camera Camera @relation(fields: [cameraId], references: [id])

  @@index([cameraId])
  @@index([startTime, endTime])
}

model CameraAccessLog {
  id         String    @id @default(uuid())
  cameraId   String
  userId     String?
  accessType String // "LIVE_VIEW", "PLAYBACK", "PTZ_CONTROL"
  startTime  DateTime
  endTime    DateTime?
  duration   Int? // in seconds
  ipAddress  String?

  // Business context
  purpose String?
  notes   String?

  createdAt DateTime @default(now())

  camera Camera @relation(fields: [cameraId], references: [id])

  @@index([cameraId])
  @@index([userId])
  @@index([startTime])
}
