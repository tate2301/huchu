# -----------------------------------------------------------------------------
# Huchu environment template
# Copy this file to `.env` and replace placeholder values.
# Never commit real credentials or tokens.
# -----------------------------------------------------------------------------

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/huchu_mines?schema=public"

# Optional local DB convenience variable (used by some local workflows)
DATABASE_URL_LOCAL="postgresql://user:password@localhost:5432/huchu_mines"

# NextAuth
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Multitenancy host enforcement
# Leave PLATFORM_ROOT_DOMAIN empty for local development and most preview envs.
# Set both values in production to enforce tenant subdomain login:
# PLATFORM_ROOT_DOMAIN="apps.pagka.dev"
# PLATFORM_ROOT_HOSTS="apps.pagka.dev"
# -----------------------------------------------------------------------------
PLATFORM_ROOT_DOMAIN=""
PLATFORM_ROOT_HOSTS="localhost:3000"

# Vercel Blob (required only if uploads are enabled)
BLOB_READ_WRITE_TOKEN=""

# Optional Postgres/Prisma tuning knobs
# PG_POOL_MAX="10"
# PG_POOL_IDLE_MS="10000"
# PG_POOL_CONN_MS="5000"
# PRISMA_TX_MAX_WAIT_MS="10000"
# PRISMA_TX_TIMEOUT_MS="60000"
# PRISMA_PROVISION_TX_MAX_WAIT_MS="20000"
# PRISMA_PROVISION_TX_TIMEOUT_MS="180000"
# PRISMA_PROVISION_TX_RETRIES="2"
