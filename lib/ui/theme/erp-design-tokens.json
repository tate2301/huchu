{
  "name": "huchu-erp-theme",
  "version": "1.0.0",
  "mode": "light-first",
  "palette": {
    "canvas": "#FCFCF4",
    "surface": "#FFFFFF",
    "surfaceMuted": "#F7F7F2",
    "border": "#E6E6E0",
    "borderStrong": "#DADAD3",
    "textPrimary": "#111111",
    "textSecondary": "#6B6B6B",
    "muted": "#6B6B6B",
    "textSubtle": "#9A9A93",
    "primary": "#4C64D4",
    "primaryHover": "#3F57C8",
    "primaryPressed": "#344BB3",
    "primarySoft": "#EEF0FF",
    "primarySoftHover": "#E4E8FF"
  },
  "status": {
    "success": "#2CA47C",
    "successSoft": "#EAF7F1",
    "danger": "#EC442C",
    "dangerSoft": "#FDEBE7",
    "warning": "#F46414",
    "warningSoft": "#FDF1E8",
    "inProgress": "#FCB414",
    "inProgressSoft": "#FFF6D6",
    "inReview": "#4C64D4",
    "inReviewSoft": "#EEF0FF",
    "pending": "#CFCFC6",
    "pendingSoft": "#F3F3EF",
    "inactive": "#9A9A93"
  },
  "semantic": {
    "background": "{palette.canvas}",
    "backgroundMuted": "{palette.surfaceMuted}",
    "card": "{palette.surface}",
    "borderDefault": "{palette.border}",
    "borderStrong": "{palette.borderStrong}",
    "textStrong": "{palette.textPrimary}",
    "textBody": "{palette.textPrimary}",
    "textMuted": "{palette.muted}",
    "textSubtle": "{palette.textSubtle}",
    "focusRing": "{palette.primary}",
    "primaryActionBg": "{palette.primary}",
    "primaryActionHover": "{palette.primaryHover}",
    "primaryActionPressed": "{palette.primaryPressed}",
    "primaryActionSoft": "{palette.primarySoft}",
    "primaryActionSoftHover": "{palette.primarySoftHover}",
    "primaryActionFg": "#FFFFFF"
  },
  "charts": {
    "palette": [
      "{palette.primary}",
      "{status.success}",
      "{status.warning}",
      "{status.danger}",
      "{status.inProgress}"
    ],
    "statusMap": {
      "passing": "{status.success}",
      "failing": "{status.danger}",
      "needChanges": "{status.warning}",
      "inReview": "{status.inReview}",
      "inProgress": "{status.inProgress}",
      "pending": "{status.pending}",
      "inactive": "{status.inactive}"
    }
  }
}
